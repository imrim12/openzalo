{
  "name": "@openzalo/zalo",
  "version": "1.0.0",
  "description": "This project was bootstrapped with Fastify-CLI.",
  "directories": {
    "test": "test"
  },
  "author": "",
  "license": "ISC",
  "keywords": [],
  "main": "app.ts",
  "scripts": {
    "test": "pnpm build && tsc -p test/tsconfig.json && c8 node --test -r ts-node/register \"test/**/*.ts\"",
    "start": "pnpm build && fastify start -l info dist/app.js",
    "build": "tsc",
    "watch": "tsc -w",
    "dev": "pnpm build && concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"npm:watch:ts\" \"npm:dev:start\"",
    "dev:start": "fastify start --ignore-watch=.ts$ -w -l info -P dist/app.js"
  },
  "dependencies": {
    "@fastify/autoload": "catalog:",
    "@fastify/sensible": "catalog:",
    "dotenv": "catalog:",
    "fastify": "catalog:",
    "fastify-cli": "catalog:",
    "fastify-plugin": "catalog:",
    "ioredis": "catalog:",
    "zca-js": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "c8": "catalog:",
    "concurrently": "catalog:",
    "fastify-tsconfig": "catalog:",
    "ts-node": "catalog:",
    "typescript": "catalog:"
  }
}
